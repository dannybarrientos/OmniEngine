# --- OMNIENGINE CONFIG ---
NODE_ENV=development
PORT=3000

# --- AI MODELS (OpenAI / Anthropic) ---
# Usaremos estos para el Generator Agent y el Critic Agent
OPENAI_API_KEY=your_key_here
ANTHROPIC_API_KEY=your_key_here

# --- VECTOR DATABASE (LanceDB) ---
# Ruta donde se guardará la memoria de largo plazo de OmniEngine
VECTOR_STORE_PATH=./data/vector_db

# --- QA SETTINGS ---
USE_CACHE=true
SELF_HEAL=true
PLAYWRIGHT_HEADLESS=false

# --- MCP (Model Context Protocol) ---
# Configuración para que la IA pueda "ver" tus archivos de spec
MCP_SERVER_URL=http://localhost:8080